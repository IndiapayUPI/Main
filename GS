<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Billing Viewer Portal</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f6f9;
            margin: 0;
            padding: 20px;
            color: #333;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }
        .container {
            width: 100%;
            max-width: 500px;
            background: #ffffff;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        h2 {
            color: #2c3e50;
            border-bottom: 2px solid #ecf0f1;
            padding-bottom: 10px;
            margin-top: 0;
            text-align: center;
        }
        .data-row {
            margin: 15px 0;
            font-size: 18px;
            display: flex;
            justify-content: space-between;
            border-bottom: 1px dashed #ccc;
            padding-bottom: 10px;
        }
        .data-label {
            font-weight: 600;
            color: #7f8c8d;
        }
        .data-value {
            font-weight: bold;
            color: #2c3e50;
        }
        .error-message {
            color: #e74c3c;
            text-align: center;
            font-weight: bold;
            padding: 20px;
            background: #fadbd8;
            border-radius: 5px;
        }
        .hidden {
            display: none;
        }
        .footer-note {
            text-align: center;
            margin-top: 20px;
            font-size: 12px;
            color: #bdc3c7;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>Billing Details</h2>

    <div id="errorMessage" class="error-message">
        No valid billing data found in the URL link.
    </div>

    <div id="billingData" class="hidden">
        <div class="data-row">
            <span class="data-label">Payer Name:</span>
            <span id="viewPayer" class="data-value">--</span>
        </div>
        <div class="data-row">
            <span class="data-label">Amount (INR):</span>
            <span class="data-value">₹<span id="viewAmount">--</span></span>
        </div>
    </div>

    <div class="footer-note">System Generated Internal View</div>
</div>

<script>
    // Page load hote hi yeh function chalega
    window.onload = function() {
        // Browser ke URL se parameters nikalna
        const urlParams = new URLSearchParams(window.location.search);
        const encodedParam = urlParams.get('data');

        // Agar URL mein '?data=' maujood hai
        if (encodedParam) {
            try {
                // Base64 string ko decode karna (atob)
                const decodedRaw = atob(encodedParam);
                
                // Decode kiye gaye text se Name aur Amount nikalna
                const params = new URLSearchParams(decodedRaw);
                const name = params.get('name');
                const amount = params.get('amt');

                // Agar dono values mil gayi hain
                if (name && amount) {
                    // HTML elements mein values daalna
                    document.getElementById('viewPayer').innerText = decodeURIComponent(name);
                    document.getElementById('viewAmount').innerText = parseFloat(amount).toLocaleString('en-IN');
                    
                    // Error message chupana aur Data dikhana
                    document.getElementById('errorMessage').classList.add('hidden');
                    document.getElementById('billingData').classList.remove('hidden');
                } else {
                    throw new Error("Missing parameters in decoded string");
                }
            } catch (error) {
                // Agar decoding mein koi error aata hai (link chhed-chhad kiya gaya ho)
                console.error("Decoding Error:", error);
                document.getElementById('errorMessage').innerText = "Corrupted or invalid link provided.";
            }
        }
    };
</script>

</body>
</html>
